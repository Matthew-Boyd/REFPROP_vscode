{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Enthalpy Test (gfortran + GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/test_enthalpy.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/..",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set disassembly flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Enthalpy Test (with directory)"
        },
