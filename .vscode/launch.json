{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug current test (GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_gnu/bin/${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set disassembly flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build current test (GNU)"
        },
        {
            "name": "Debug current test (Intel)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_intel/bin/Debug/${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:/Program Files (x86)/Intel/oneAPI/compiler/latest/bin;${env:PATH}"
                }
            ],
            "console": "internalConsole",
            "preLaunchTask": "Build current test (Intel)"
        },
        {
            "name": "Debug current test (Intel WSL)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_intel_wsl/bin/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "internalConsole",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Fortran case-insensitive symbols",
                    "text": "set case-sensitive off",
                    "ignoreFailures": false
                },
                {
                    "description": "Fortran array lower bound fix",
                    "text": "set fortran-array-ambiguous on",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build current test (Intel WSL)"
        },
        {
            "name": "Debug test by name (GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_gnu/bin/${input:testName}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set disassembly flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build test by name (GNU)"
        },
        {
            "name": "Debug test by name (Intel)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_intel/bin/Debug/${input:testName}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:/Program Files (x86)/Intel/oneAPI/compiler/latest/bin;${env:PATH}"
                }
            ],
            "console": "internalConsole",
            "preLaunchTask": "Build test by name (Intel)"
        },
        {
            "name": "Debug test by name (Intel WSL)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_intel_wsl/bin/${input:testName}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "internalConsole",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Fortran case-insensitive symbols",
                    "text": "set case-sensitive off",
                    "ignoreFailures": false
                },
                {
                    "description": "Fortran array lower bound fix",
                    "text": "set fortran-array-ambiguous on",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build test by name (Intel WSL)"
        }
    ],
    "inputs": [
        {
            "id": "testName",
            "type": "promptString",
            "description": "Enter the test name (e.g., test_enthalpy)",
            "default": "test_enthalpy"
        }
    ]
}
