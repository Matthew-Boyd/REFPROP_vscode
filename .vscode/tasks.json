{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build current test (gfortran)",
            "type": "shell",
            "command": "gfortran",
            "args": [
                "-g",
                "-fbacktrace",
                "-fcheck=all",
                "-Wall",
                "-O0",
                "-ffixed-form",
                "-ffixed-line-length-none",
                "-I", "${workspaceFolder}",
                "-o", "${workspaceFolder}/build/bin/${fileBasenameNoExtension}.exe",
                "${workspaceFolder}/tests/utils.FOR",
                "${file}",
                "${workspaceFolder}/DLLFILES/PASS_FTN.FOR",
                "${workspaceFolder}/REFPROP.FOR",
                "${workspaceFolder}/PROP_SUB.FOR",
                "${workspaceFolder}/FLSH_SUB.FOR",
                "${workspaceFolder}/SAT_SUB.FOR",
                "${workspaceFolder}/SETUP.FOR",
                "${workspaceFolder}/CORE_FEQ.FOR",
                "${workspaceFolder}/CORE_ANC.FOR",
                "${workspaceFolder}/CORE_PR.FOR",
                "${workspaceFolder}/MIX_HMX.FOR",
                "${workspaceFolder}/TRNSP.FOR",
                "${workspaceFolder}/TRNS_VIS.FOR",
                "${workspaceFolder}/TRNS_TCX.FOR",
                "${workspaceFolder}/UTILITY.FOR"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compile the currently open test file with debug symbols"
        },
        {
            "label": "Build test by name (gfortran)",
            "type": "shell",
            "command": "gfortran",
            "args": [
                "-g",
                "-fbacktrace",
                "-fcheck=all",
                "-Wall",
                "-O0",
                "-ffixed-form",
                "-ffixed-line-length-none",
                "-I", "${workspaceFolder}",
                "-o", "${workspaceFolder}/build/bin/${input:testName}.exe",
                "${workspaceFolder}/tests/utils.FOR",
                "${workspaceFolder}/tests/${input:testName}.FOR",
                "${workspaceFolder}/DLLFILES/PASS_FTN.FOR",
                "${workspaceFolder}/REFPROP.FOR",
                "${workspaceFolder}/PROP_SUB.FOR",
                "${workspaceFolder}/FLSH_SUB.FOR",
                "${workspaceFolder}/SAT_SUB.FOR",
                "${workspaceFolder}/SETUP.FOR",
                "${workspaceFolder}/CORE_FEQ.FOR",
                "${workspaceFolder}/CORE_ANC.FOR",
                "${workspaceFolder}/CORE_PR.FOR",
                "${workspaceFolder}/MIX_HMX.FOR",
                "${workspaceFolder}/TRNSP.FOR",
                "${workspaceFolder}/TRNS_VIS.FOR",
                "${workspaceFolder}/TRNS_TCX.FOR",
                "${workspaceFolder}/UTILITY.FOR"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "group": "build",
            "detail": "Compile a test file by name (will prompt for name)"
        },
        {
            "label": "Create build directories",
            "type": "shell",
            "command": "cmd",
            "args": ["/c", "if not exist build\\bin mkdir build\\bin"],
            "problemMatcher": []
        },
        {
            "label": "Build current test (with directory)",
            "dependsOn": ["Create build directories", "Build current test (gfortran)"],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build test by name (with directory)",
            "dependsOn": ["Create build directories", "Build test by name (gfortran)"],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake",
            "args": ["-S", ".", "-B", "build"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "detail": "Configure CMake build"
        },
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "detail": "Build all targets with CMake"
        },
        {
            "label": "CTest Run All",
            "type": "shell",
            "command": "ctest",
            "args": ["--output-on-failure"],
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "problemMatcher": [],
            "detail": "Run all tests with CTest"
        }
    ],
    "inputs": [
        {
            "id": "testName",
            "type": "promptString",
            "description": "Enter the test name (e.g., test_enthalpy)",
            "default": "test_enthalpy"
        }
    ]
}
