{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build current test (GNU)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build_gnu",
                "--target", "${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Incremental build of the current test (gfortran/Ninja)"
        },
        {
            "label": "Build current test (Intel)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build_intel",
                "--config", "Debug",
                "--target", "${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "group": "build",
            "detail": "Incremental build of the current test (ifx/VS2022)"
        },
        {
            "label": "Build current test (Intel WSL)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "source /opt/intel/oneapi/setvars.sh --force > /dev/null && cmake --build build_intel_wsl --target ${fileBasenameNoExtension} -- -j$(nproc)"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "group": "build",
            "detail": "Incremental build of the current test (ifx/WSL)"
        },
        {
            "label": "Build test by name (GNU)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build_gnu",
                "--target", "${input:testName}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "group": "build",
            "detail": "Incremental build of a named test (gfortran/Ninja)"
        },
        {
            "label": "Build test by name (Intel)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build_intel",
                "--config", "Debug",
                "--target", "${input:testName}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "group": "build",
            "detail": "Incremental build of a named test (ifx/VS2022)"
        },
        {
            "label": "Build test by name (Intel WSL)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "source /opt/intel/oneapi/setvars.sh --force > /dev/null && cmake --build build_intel_wsl --target ${input:testName} -- -j$(nproc)"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "group": "build",
            "detail": "Incremental build of a named test (ifx/WSL)"
        },
        {
            "label": "CMake Build (Intel WSL)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "source /opt/intel/oneapi/setvars.sh --force > /dev/null && cmake --build build_intel_wsl -- -j$(nproc)"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "CMake Configure (Intel WSL)",
            "problemMatcher": ["$gcc"],
            "detail": "Build with Intel ifx on WSL"
        },
        {
            "label": "CMake Configure (GNU)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", ".",
                "-B", "build_gnu",
                "-G", "Ninja"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "detail": "Configure CMake build with Ninja + gfortran"
        },
        {
            "label": "CMake Configure (Intel)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", ".",
                "-B", "build_intel",
                "-G", "Visual Studio 17 2022",
                "-DCMAKE_Fortran_COMPILER=C:/Program Files (x86)/Intel/oneAPI/compiler/latest/bin/ifx.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "detail": "Configure CMake build with VS2022 + Intel ifx"
        },
        {
            "label": "CMake Configure (Intel WSL)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "source /opt/intel/oneapi/setvars.sh --force > /dev/null && cmake -S . -B build_intel_wsl -G 'Unix Makefiles' -DCMAKE_Fortran_COMPILER=ifx -DCMAKE_BUILD_TYPE=Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "detail": "Configure CMake build with Intel ifx on WSL"
        },
        {
            "label": "CTest Run All (GNU)",
            "type": "shell",
            "command": "ctest",
            "args": ["--output-on-failure"],
            "options": {
                "cwd": "${workspaceFolder}/build_gnu"
            },
            "problemMatcher": [],
            "detail": "Run all tests with CTest (GNU build)"
        },
        {
            "label": "CTest Run All (Intel)",
            "type": "shell",
            "command": "ctest",
            "args": ["--output-on-failure", "--build-config", "Debug"],
            "options": {
                "cwd": "${workspaceFolder}/build_intel"
            },
            "problemMatcher": [],
            "detail": "Run all tests with CTest (Intel build)"
        }
    ],
    "inputs": [
        {
            "id": "testName",
            "type": "promptString",
            "description": "Enter the test name (e.g., test_enthalpy)",
            "default": "test_enthalpy"
        }
    ]
}
