{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build test_enthalpy (gfortran)",
            "type": "shell",
            "command": "gfortran",
            "args": [
                "-g",
                "-fbacktrace",
                "-fcheck=all",
                "-Wall",
                "-O0",
                "-ffixed-form",
                "-ffixed-line-length-none",
                "-I", "${workspaceFolder}",
                "-o", "${workspaceFolder}/build/bin/test_enthalpy.exe",
                "${workspaceFolder}/tests/utils.FOR",
                "${workspaceFolder}/tests/test_enthalpy.FOR",
                "${workspaceFolder}/DLLFILES/PASS_FTN.FOR",
                "${workspaceFolder}/REFPROP.FOR",
                "${workspaceFolder}/PROP_SUB.FOR",
                "${workspaceFolder}/FLSH_SUB.FOR",
                "${workspaceFolder}/SAT_SUB.FOR",
                "${workspaceFolder}/SETUP.FOR",
                "${workspaceFolder}/CORE_FEQ.FOR",
                "${workspaceFolder}/CORE_ANC.FOR",
                "${workspaceFolder}/CORE_PR.FOR",
                "${workspaceFolder}/MIX_HMX.FOR",
                "${workspaceFolder}/TRNSP.FOR",
                "${workspaceFolder}/TRNS_VIS.FOR",
                "${workspaceFolder}/TRNS_TCX.FOR",
                "${workspaceFolder}/UTILITY.FOR"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compile test_enthalpy with debug symbols"
        },
        {
            "label": "Create build directories",
            "type": "shell",
            "command": "cmd",
            "args": ["/c", "if not exist build\\bin mkdir build\\bin"],
            "problemMatcher": []
        },
        {
            "label": "Build test_enthalpy (with directory)",
            "dependsOn": ["Create build directories", "Build test_enthalpy (gfortran)"],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake",
            "args": ["-S", ".", "-B", "build"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "detail": "Configure CMake build"
        },
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "detail": "Build all targets with CMake"
        },
        {
            "label": "CTest Run All",
            "type": "shell",
            "command": "ctest",
            "args": ["--output-on-failure"],
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "problemMatcher": [],
            "detail": "Run all tests with CTest"
        }
    ]
}
